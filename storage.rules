rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * Nabídkové obrázky a přílohy — veřejné čtení kvůli zobrazení v katalogu.
     * Zápis jen vlastní složka, typ a velikost omezeny.
     */
    match /uploads/{userId}/offers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    /**
     * Avatar v profilu — stejný model (veřejné čtení v UI).
     */
    match /uploads/{userId}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
