rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isInParticipants(ids) {
      return isAuthed() && request.auth.uid in ids;
    }

    /** Lexikograficky seřazené UID pro deterministické id 1:1 chatu. */
    function sortedTwoUids(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    /** Dokument /chats/{chatId} musí odpovídat účastníkům (zabraňuje nesouladu id vs. obsah). */
    function validChatIdForParticipants(chatId, p) {
      return p is list
        && (
          (p.size() == 1
            && p[0] == request.auth.uid
            && chatId.matches('^solo_' + request.auth.uid + '_offer_.+'))
          || (p.size() == 2
            && p[0] is string
            && p[1] is string
            && chatId == sortedTwoUids(p[0], p[1]))
        );
    }

    /** 1 = solo thread, 2 = dvou stran – žádné „přidání“ cizího UID později při update */
    function validParticipantListOnCreate() {
      let p = request.resource.data.participantIds;
      return p is list
        && p.size() > 0
        && p.size() < 3
        && isInParticipants(p);
    }

    function participantListUnchanged() {
      return request.resource.data.participantIds == resource.data.participantIds;
    }

    function validMessageText() {
      return request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000;
    }

    function validMessageCreate() {
      return request.resource.data.keys().hasOnly(['senderId', 'text', 'createdAt'])
        && request.resource.data.senderId == request.auth.uid
        && validMessageText();
    }

    function chatForMessage(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function validOfferStatus(s) {
      return s == 'active' || s == 'paused' || s == 'completed' || s == 'deleted';
    }

    function validTradeStatus(s) {
      return s == 'pending' || s == 'accepted' || s == 'declined';
    }

    match /users/{userId} {
      allow read: if isAuthed();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'bio',
          'location',
          'avatarUrl',
          'completedTrades',
          'ratingAvg',
          'ratingCount',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'bio',
          'location',
          'avatarUrl',
          'completedTrades',
          'ratingAvg',
          'ratingCount',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.sellerId == request.auth.uid
        && validOfferStatus(request.resource.data.status)
        && request.resource.data.keys().hasOnly([
          'title',
          'description',
          'wantsInReturn',
          'category',
          'location',
          'lat',
          'lng',
          'isRemote',
          'image',
          'images',
          'attachments',
          'tags',
          'sellerId',
          'sellerName',
          'sellerAvatar',
          'status',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isAuthed()
        && resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.createdAt == resource.data.createdAt
        && validOfferStatus(request.resource.data.status)
        && request.resource.data.keys().hasOnly([
          'title',
          'description',
          'wantsInReturn',
          'category',
          'location',
          'lat',
          'lng',
          'isRemote',
          'image',
          'images',
          'attachments',
          'tags',
          'sellerId',
          'sellerName',
          'sellerAvatar',
          'status',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /tradeRequests/{requestId} {
      allow read: if isAuthed() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.requesterId == request.auth.uid
      );

      allow create: if isAuthed()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId != request.auth.uid
        && validTradeStatus(request.resource.data.status)
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'offerId',
          'offerTitle',
          'requesterId',
          'requesterName',
          'ownerId',
          'ownerName',
          'status',
          'completedBy',
          'createdAt',
          'updatedAt'
        ]);

      allow update: if isAuthed()
        && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.requesterId == request.auth.uid
        )
        && request.resource.data.offerId == resource.data.offerId
        && request.resource.data.offerTitle == resource.data.offerTitle
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.ownerName == resource.data.ownerName
        && request.resource.data.createdAt == resource.data.createdAt
        && validTradeStatus(request.resource.data.status)
        && request.resource.data.keys().hasOnly([
          'offerId',
          'offerTitle',
          'requesterId',
          'requesterName',
          'ownerId',
          'ownerName',
          'status',
          'completedBy',
          'createdAt',
          'updatedAt'
        ]);

      allow delete: if false;
    }

    match /chats/{chatId} {
      /**
       * Párový chat bez pozvánky stále umožňuje „vynucený“ thread (viz bezpečnostní audit).
       * Doplňte invite flow nebo Cloud Function, pokud chcete souhlas druhé strany.
       */
      allow read: if isInParticipants(resource.data.participantIds);
      allow create: if validParticipantListOnCreate()
        && validChatIdForParticipants(chatId, request.resource.data.participantIds);
      allow update: if isInParticipants(resource.data.participantIds)
        && participantListUnchanged();
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isInParticipants(chatForMessage(chatId).participantIds);
        allow create: if isInParticipants(chatForMessage(chatId).participantIds)
          && validMessageCreate();
        allow update, delete: if false;
      }
    }

    /** Skrytí konverzace jen v mém seznamu (dokument v chats/ zůstává kvůli pravidlům zpráv). */
    match /users/{userId}/hiddenChats/{chatId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }
  }
}
