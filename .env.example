# Zkopíruj do .env a doplň hodnoty z Firebase Console → Project settings → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Volitelné: druhé Firebase UID pro test 1:1 chatu (jiný prohlížeč / účet)
# VITE_DEMO_OPPOSITE_UID=

# --- Nasazení backendu (Firestore + Storage pravidla + indexy) ---
# 1) npm install
# 2) Zkopíruj tento soubor na .firebaserc a nastav stejné project ID jako VITE_FIREBASE_PROJECT_ID:
#    cp .firebaserc.example .firebaserc   (a uprav "default")
# 3) npx firebase login
# 4) npm run firebase:deploy:backend
#
# Ve Firebase Console: Authentication → Anonymous ON; Storage vytvořený bucket;
# API klíč v GCP Credentials → bez restriktivních referrerů nebo přidej localhost + Vercel doménu.
#
# Authentication → Sign-in method: zapněte „E-mail/heslo“, „Google“ a (pro chat) „Anonymous“.
